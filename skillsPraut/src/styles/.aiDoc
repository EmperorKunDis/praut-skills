tokens.ts: colors | gradients | fonts | fontWeight | typeScale | frame | frameShort | frameSquare | glow | springs | timing | channel | seriesColors | pickTagline | withOpacity | safeZone | layouts | nav | episodeHeader | hierarchy | webcam | defOverlay | screenshot | Tokens (type)

@VARS_CONSTANTS
colors.navy.950: "#060818" — frame bg darkest
colors.navy.900: "#0a0e2e" — slide content bg
colors.navy.800: "#0f1440" — card base
colors.blue.400: "#506FFB" — primary border + logo mark
colors.purple.50: "#FAF5FF" — heading text
colors.purple.200: "#E4CFFF" — body text
colors.purple.600: "#8D2AF3" — main CTA
colors.semantic: { success, warning, error, info }
fonts.primary: '"Montserrat", sans-serif'
fonts.mono: '"IBM Plex Mono", monospace'
fontWeight: body=500 | bodyEmphasis=600 | heading=700 | display=800
frame: {1920×1080, topBarHeight=72, borderColor=blue.400, bg=navy.950}
frameShort: 1080×1920 9:16 | frameSquare: 1080×1080 1:1
springs: smooth | bouncy | snappy | gentle
timing: instant=6 | fast=12 | medium=24 | slow=45 | reveal=60 (frames @30fps)
safeZone.padding: 64 — no content within
layouts: singleFocus (maxWidth 80%) | splitScreen (35/65, gap 48)
channel: { name="Martin Švanda", episodePrefix="EP", taglines[9] }
webcam: { size=240, shape=square, background=#00FF00, position=bottom-right, inset=48 }
defOverlay: { position=top-center, horizontalPadding=15%, topOffset=90, maxWidth=1000 }
screenshot: { borderRadius=12, glow=purple, gridColor=faint-purple }

@FUNCTIONS
pickTagline(episodeNumber?: string) → string
  purpose: deterministic tagline hash of episode number
  side-effects: none
withOpacity(hex: string, alpha: 0..1) → "#RRGGBBAA"
  purpose: append 8-bit alpha to 6-digit hex
  side-effects: none

@INTERFACES
Tokens: { colors, gradients, fonts, fontWeight, typeScale, frame, glow, springs, timing, safeZone, layouts, nav, episodeHeader, hierarchy, webcam, defOverlay, screenshot }

@STANDARDS
- SINGLE SOURCE OF TRUTH — every component imports from here
- NEVER hardcode hex anywhere else
- fontWeight ≥ 500 on dark mode
- glow.* instead of drop-shadow rgba(0,0,0,*)
- springs.* for all animations | timing.* for all durations
- seriesColors = [purple.600, blue.400, blue.500, purple.700] — max 4 series
- hierarchy rules: heading ≥ 28px | body ≤ 23px | footnote ≤ 18px | DefOverlay ≤ 70% width
- WCAG: AAA for #FAF5FF/#E4CFFF/#D6B0FF on navy.950 | blue.400 AA only at 18px+ bold

@WARNINGS
- ❌ #000000 bg | ❌ #FFFFFF text | ❌ purple as bg area | ❌ fontWeight < 500
- ❌ drop shadows on dark mode | ❌ #BC7EFF as main text (insufficient contrast)
- ❌ Logo near webcam | ❌ unprocessed photos (need borderRadius + glow)
- ❌ > 2 accent colors concurrent | ❌ free layout outside layouts.*
- ❌ content within safeZone.padding (64px) | ❌ DefOverlay bigger than main message
- ❌ heading smaller than body below | ❌ duplicate term definitions
